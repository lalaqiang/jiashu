<?xml version="1.0" encoding="utf-8"?>
<!--
    录制模式覆盖层
    - 全屏半透明（轻微暗化）便于辨识录制中
    - 顶部居中「停止录制」按钮（红色）
    - 底部居中提示文字
    点击屏幕任意非按钮区域 = 添加点位
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/record_overlay_bg">

    <!-- 顶部停止按钮 -->
    <Button
        android:id="@+id/btnStopRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="24dp"
        android:text="@string/btn_record_stop"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/btn_record_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:minWidth="0dp"
        android:minHeight="0dp" />

    <!-- 底部提示 + 计数 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tvRecordHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/record_hint"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:background="#80000000"
            android:padding="10dp" />

        <TextView
            android:id="@+id/tvRecordCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/record_count"
            android:textColor="@color/record_red"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
